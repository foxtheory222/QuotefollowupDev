+          await saveBudgetArchiveRow(root, button, state);
+        } catch (error) {
+          FLASH_MESSAGE = { tone: "error", text: "Budget target save failed: " + error.message };
+          await renderRoot(root);
+        } finally {
+          if (document.body.contains(button)) {
+            button.disabled = false;
+          }
+        }
+      });
+    });
+  }
+
+  function scheduleRerender(root) {
+    if (!root || root.dataset.qfuRuntimeRenderScheduled === "1") {
+      return;
+    }
+    root.dataset.qfuRuntimeRenderScheduled = "1";
+    window.setTimeout(function () {
+      if (!document.body.contains(root)) {
+        return;
+      }
+      root.dataset.qfuRuntimeRenderScheduled = "";
+      renderRoot(root).catch(function (error) {
+        console.error("QFU runtime rerender failed", error);
+      });
+    }, 60);
+  }
+
+  function observeRoot(root) {
+    if (!root || OBSERVERS.has(root)) {
+      return;
+    }
+    var observer = new MutationObserver(function () {
+      if (root.dataset.qfuRuntimeRendering === "1") {
+        return;
+      }
+      if (!root.querySelector("[data-qfu-runtime-signature]")) {
+        scheduleRerender(root);
+      }
+    });
+    observer.observe(root, { childList: true });
+    OBSERVERS.set(root, observer);
+  }
+
+  async function renderRoot(root) {
+    observeRoot(root);
+    var state = await loadRuntime();
+    var pageType = root.getAttribute("data-page");
+    var branchSlug = root.getAttribute("data-branch") || "";
+    var regionSlug = root.getAttribute("data-region") || "";
+    var branch = branchSlug ? state.branchMap[branchSlug] : null;
+    var region = regionSlug ? state.regionMap[regionSlug] : null;
+    var viewKey = new URLSearchParams(window.location.search).get("view") || "follow-up-queue";
+    var html = "";
+
+    if (pageType === "hub") {
+      html = renderHub(state);
+    } else if (pageType === "region" && region) {
+      html = renderRegionLive(region);
+    } else if (pageType === "branch" && branch) {
+      html = renderBranchLive(branch);
+    } else if (pageType === "detail" && branch) {
+      html = await renderDetailLive(branch, viewKey);
+    } else if (pageType === "ops") {
+      html = renderOps(state);
+    } else {
+      html = '<div class="qfu-phase0-shell"><div class="qfu-phase0-empty-state"><strong>Page configuration missing</strong><p class="qfu-phase0-empty-copy">QFU runtime metadata was not found for this route.</p></div></div>';
+    }
+
+    html = renderRuntimeDiagnosticsMarkup(state, {
+      pageType: pageType,
+      branchSlug: branchSlug,
+      regionSlug: regionSlug
+    }) + html;
+
+    root.dataset.qfuRuntimeRendering = "1";
+    root.innerHTML = managedHtml(html);
+    root.dataset.qfuRuntimeRendering = "";
+    root.dataset.qfuRuntimeManaged = "1";
+
+    if (pageType === "ops") {
+      bindOpsActions(root, state);
+    } else if (pageType === "branch") {
+      bindDashboardPaging(root);
+    } else if (pageType === "detail" && branch && viewKey === "ready-to-ship-not-pgid") {
+      bindDeliveryNotPgiActions(root, branch);
+    }
+  }
+
+  function renderRuntimeFailure(root, error) {
+    console.error("QFU regional runtime failed", error);
+    root.innerHTML = managedHtml('<div class="qfu-phase0-shell"><div class="qfu-phase0-empty-state"><strong>Regional runtime failed</strong><p class="qfu-phase0-empty-copy">' + escapeHtml(error.message) + "</p></div></div>");
+  }
+
+  function bindDashboardPaging(root) {
+    if (root.dataset.qfuDashboardPagingBound === "1") {
+      return;
+    }
+
+    root.addEventListener("click", function (event) {
+      var target = event.target;
+      var button = target && target.closest ? target.closest("[data-qfu-dashboard-page]") : null;
+      if (!button || !root.contains(button)) {
+        return;
+      }
+
+      event.preventDefault();
+      var paramName = button.getAttribute("data-qfu-dashboard-page");
+      var pageNumber = parseInt(button.getAttribute("data-qfu-page-number") || "1", 10);
+      if (!paramName || !Number.isFinite(pageNumber) || dashboardPageValue(paramName) === pageNumber) {
+        return;
+      }
+
+      window.history.pushState({ qfuDashboardPage: true }, "", dashboardPageHref(paramName, pageNumber));
+      renderRoot(root).catch(function (error) {
+        renderRuntimeFailure(root, error);
+      });
+    });
+
+    root.dataset.qfuDashboardPagingBound = "1";
+  }
+
+  function bindPopState() {
+    if (document.body.dataset.qfuRuntimePopstateBound === "1") {
+      return;
+    }
+
+    window.addEventListener("popstate", function () {
+      var roots = document.querySelectorAll("[data-qfu-phase0]");
+      Array.prototype.forEach.call(roots, function (root) {
+        renderRoot(root).catch(function (error) {
+          renderRuntimeFailure(root, error);
+        });
+      });
+    });
+
+    document.body.dataset.qfuRuntimePopstateBound = "1";
+  }
+
+  function mount() {
+    bindPopState();
+    var roots = document.querySelectorAll("[data-qfu-phase0]");
+    Array.prototype.forEach.call(roots, function (root) {
+      renderRoot(root).catch(function (error) {
+        renderRuntimeFailure(root, error);
+      });
+    });
+  }
+
+  document.addEventListener("DOMContentLoaded", mount);
+})();
+
+</script>
