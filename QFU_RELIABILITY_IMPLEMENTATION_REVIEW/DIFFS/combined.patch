+  $parameters = [ordered]@{
+    mailboxAddress = "@parameters('qfu_QFU_SharedMailboxAddress')"
+    folderId = "@parameters('qfu_QFU_SharedMailboxFolderId')"
+    includeAttachments = $true
+    importance = "Any"
