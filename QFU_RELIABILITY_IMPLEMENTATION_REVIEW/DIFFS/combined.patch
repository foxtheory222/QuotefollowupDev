+  )
+
+  if ($Object -is [System.Collections.IDictionary]) {
+    if ($Object.Contains($Name)) {
+      $Object.Remove($Name)
+    }
+    return
+  }
+
+  if ($Object -and $Object.PSObject.Properties[$Name]) {
+    $Object.PSObject.Properties.Remove($Name)
+  }
+}
